rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "tukukalandi@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny
    match /{document=**} { allow read, write: if false; }

    // Allow public read for all educational content
    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Portal Documents
    function isValidPortalDoc(data) {
      return data.keys().hasAll(['category', 'subType', 'name', 'link', 'createdBy', 'createdAt', 'updatedAt'])
        && data.category is string && data.category.size() <= 200
        && data.subType is string && data.subType.size() <= 200
        && data.name is string && data.name.size() <= 1000
        && data.link is string && data.link.size() <= 5000
        && (!('description' in data) || (data.description is string && data.description.size() <= 5000))
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /portal_documents/{docId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPortalDoc(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['subType', 'name', 'description', 'link', 'updatedAt'])
        && incoming().updatedAt == request.time
      );
      allow delete: if isAdmin();
    }
  }
}
