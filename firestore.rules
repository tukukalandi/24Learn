rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for all educational content
    match /classes/{classId} {
      allow read, write: if true;
    }
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == "tukukalandi@gmail.com" || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == "tukukalandi@gmail.com" || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
