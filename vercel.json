{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.ts",
      "check": true
    },
    {
      "src": "/auth/(.*)",
      "dest": "server.ts",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "server.ts",
      "check": true
    }
  ]
}
